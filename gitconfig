[user]
	name = Konstantin Zverev
	email = konstantin.zverev@gmail.com
[core]
	editor = vim
	pager = less -RFX
	compression = 9
	autocrlf = input
	excludesfile = $HOME/.gitignore
[merge]
	tool = vimdiff
[push]
	default = simple
[color]
	branch = auto
	diff = auto
	interactive = auto
	        ui = true
[guitool "Edit"]
	cmd = mvim -f $FILENAME
	noconsole = yes
	needsfile = yes
[rerere]
	enabled = 1
[gui]
	editor = mvim
	needsfile = yes
[guitool "mergetool"]
	cmd = git mergetool -y -t mvim -d -f $FILENAME
	noconsole = yes
	needsfile = yes
[mergetool]
	keepBackup = false
[alias]
	s = status
	l = log --graph --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(white)- %an, %ar%Creset'
