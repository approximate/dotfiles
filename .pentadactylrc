" ~/.pentadactyl | vi: set ft=vim:

" These settings prevent Pentadactyl from overwriting my preferred Firefox settings.
set! browser.startup.page=1

set runtimepath=~/.pentadactyl,~/pentadactyl

loadplugins '\.(js|penta)$'
group user

" Bypass keyborad shortcuts for GMail
set passkeys+=www.google.com/reader:jkarfgtau:?,gt,ga,gu
set passkeys+=mail.google.com:'!#*+-./<C-Down><C-s><Enter>?INU[]acefjklmnopqrsuvxyz',*a,*n,*r,*s,*t,*u,ga,gc,gd,gi,gl,gs,gt,yo
set strictfocus=google.com:laissez-faire,'chrome:*':laissez-faire,*:moderate


" Miscellaneous
"" Remember 50 commands.
set history=50
"" Allow focus changes.
""" See https://code.google.com/p/dactyl/issues/detail?id=241.
""" Seems problematic with Google+ but works elsewhere.
set strictfocus=*:laissez-faire

" Awesome Bar
"" See http://developernotes.com/archive/2008/09/22/vimperator-tip-awesome-bar.aspx.
"" Additional 'search' option gives initial suggestion of search engine but (mistakenly?)
"" enables suggestions (which should only occur given 'suggestion'). Useful, but I'll favor
"" privacy/security.
set complete=location,file

" Display
"" show only the tab bar and bookmarks bar
set guioptions=BCnrs
"" see http://code.google.com/p/vimperator-labs/issues/detail?id=311
set popups=tab,resized
set tabclose=previous,opener,left,right

" Find
"" perform incremental searching
set incfind
"" highlight search results
set hlfind
"" only consider case if an upper case char is used
set findcase=smart

" Maps
"" Note: Since about Vimperator 2.2 (pre-Pentadactyl), one must use S-char (shift+char) instead of CHAR (uppercase).
""" Passthrough
"""" Next
" map i <C-v>
"""" Continuous
" map i <C-v>
" map I <C-z>
""" Stop
" map <Esc> <C-c>
""" Site Opening
map  <C-l> o
imap <C-l> <Esc>o
map  <C-S-l> t
imap <C-S-l> <Esc>t
map  <C-e> O
imap <C-e> <Esc>O
""" Navigation
map < H
map > L
""" Searching (Google)
map  <C-k> ogoogle<Space>
imap <C-k> <Esc>ogoogle<Space>
map  <C-S-k> tgoogle<Space>
imap <C-S-k> <Esc>tgoogle<Space>
""" Firefox Dialogs
"""" Downloads
map -builtin  <C-j> :downloads<CR>
imap -builtin <C-j> <Esc>:downloads<CR>
cmap -builtin <C-j> :downloads<CR>
""" Tabs
"""" Modified Firefox Hotkey(s)
nmap -builtin <C-t> <C-v><C-t>o
imap -builtin <C-t> <C-v><C-t>o

""" Better search
nmap <S-S> :tabopen ddg
nmap s :open ddg 


"""" (Custom) Vim-like Tabs
""""" See http://dailyvim.blogspot.com/2008/11/tabs.html.
map ,to <C-v><C-t>
map ,tf t
map ,tc d
map ,tn <C-Tab>
map ,tp <S-C-Tab>

" Additional tab navigation keybindings
nmap <S-J> gT
nmap <S-K> gt

""" Mode Overrides
"""" Insert Mode
imap <C-t> <Esc><C-v><C-t>
imap <C-w> <Esc><C-w>
"""" Command Mode
cmap <C-k> <Esc><C-k>
cmap <C-l> <Esc><C-l>
cmap <C-t> <Esc><C-v><C-t>
map -count -modes=n,v s <count>\:open<Space>duckduckgo<Space><args>

" Map Q to "allow JS from local domain"
nmap -builtin <S-q> :set noscript-tempsites!=<A-Tab><CR>
"
" These two commands do not work because of the spaces
" Map V to RSS subscription
nmap <S-v> -ex emenu Bookmarks.Subscribe To Page..<CR>
" Map V to add to Evernote
nmap <S-e> -ex emenu Tools.Add To Evernote<CR>

" Style
"" See http://bbs.archlinux.org/viewtopic.php?id=69123
"" See http://github.com/VoQn/vimperator-colorscheme/raw/e13afec1be5ec1c9de775d0e2a464862f8d3a453/colors/default.vimp
hi CompItem  font-size: 12px;
hi CompTitle color: magenta; font-weight: bold; font-size: 12px;

" Commands
"" Open Localhost
command! localhost open http://localhost
"" App Tabs
command! app pin!
" Quick translate with Lingvo
command! -nargs=+ tr tabopen lingvo <args>


" JavaScript
"" Window
:js var win = window.content.wrappedJSObject;
"" Element Toggle
""" See http://vimperator.org/trac/ticket/2.
:js <<EOJS
  toggle_element = function(name) {
    document.getElementById(name).collapsed ^= 1;
  }
EOJS
"
"" Amazon Universal Wishlist
""" JS derived from http://www.amazon.com/wishlist/get-button (also see Delicious credits above).
"""" NOTE: If not already logged into Amazon.com, this will not always work ('&' isn't handled
""""       by Amazon when passing through login).
command! amzwishlist js add_to_amazon_wishlist();
:js <<EOJS
  add_to_amazon_wishlist = function() {
    var display = function() {
      auwl = win['AUWLBook']
      if (auwl) {
        auwl.showPopover();
      } else {
        setTimeout(display, 200);
      }
    };
    var script = win.document.createElement('script');
    script['src'] = 'https://www.amazon.com/wishlist/add.js'
                    + '?loc=' + encodeURIComponent(window.location);
    win.document.body.appendChild(script);
    display();
  }
EOJS

