"\e[1~": beginning-of-line
"\e[2~": quoted-insert
"\e[3~": delete-char
"\e[4~": end-of-line
"\e[5~": history-search-backward
"\e[6~": history-search-forward
"\e[5C": forward-word
"\e[5D": backward-word
"\e\e[C": forward-word
"\e\e[D": backward-word
"\e[B": history-search-forward
"\e[A": history-search-backward

# Function Keys
#"[11~": F1
#"[11~": F2
#"[13~": F3
#"[14~": F4
#"[15~": F5
#"[17~": F6
#"[18~": F7
#"[19~": F8
#"[20~": F9
#"[21~": F10
#"[23~": F11
#"[24~": F12


# set show-all-if-ambiguous on
set bell-style visible
set completion-ignore-case on
set completion-query-items 20
set convert-meta off
set enable-keypad
set expand-tilde on
set horizontal-scroll-mode off
set input-meta on
set mark-directories on
set mark-symlinked-directories on
set output-meta on
set visible-stats on
$if Bash
	Space: magic-space
$endif

"\M-o": "\C-p\C-a\M-f "

# turn the numpad keys on
"\eOQ":         "/"
"\eOR":         "*"
"\eOS":         "-"
"\eOk":         "+"
"\eOl":         "+"
"\eOM":         accept-line

# Colon and dot
#"\eOl":       ","
"\eOn":         "."

# Numbers
"\eOp":         "0"
"\eOq":         "1"
"\eOr":         "2"
"\eOs":         "3"
"\eOt":         "4"
"\eOu":         "5"
"\eOv":         "6"
"\eOw":         "7"
"\eOx":         "8"
"\eOy":         "9"
